# Get this from https://discord.com/developers/applications -> Your App -> Bot -> Token
DISCORD_TOKEN=your_bot_token_here

# Your Discord application's client ID (also in developer portal)
CLIENT_ID=your_client_id_here

# Name of the channel where weekly reports will be posted
# Bot will fall back to the first text channel it can write to
REPORT_CHANNEL=activity-reports

# Day of week for reports: 0=Sunday, 1=Monday ... 6=Saturday
REPORT_DAY=0

# Hour to send the report (24h, server UTC time)
REPORT_HOUR=9
